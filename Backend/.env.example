# Copy this file to .env and fill in your actual values
# .env is gitignored — this file IS committed so teammates know what vars are needed

PORT=5000

# MongoDB Atlas connection string (get from Atlas → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/zync?retryWrites=true&w=majority

# JWT secret — make this a long random string in production (use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Anthropic Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (for CORS — change in production)
CLIENT_URL=http://localhost:5173
