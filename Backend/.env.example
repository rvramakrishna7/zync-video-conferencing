

PORT=5000

# MongoDB Atlas connection string (get from Atlas → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/zync?retryWrites=true&w=majority

# JWT secret 
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Groq API
GROQ_API_KEY=sk-ant-...

# Google OAuth 
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL 
CLIENT_URL=http://localhost:5173
